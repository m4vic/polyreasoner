# Backend Selection
# Options: ollama, api
POLYREASONER_BACKEND=ollama

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# API Settings (LiteLLM)
LITELLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Shield/Security Settings
SHIELD_LEVEL=5

# Optional: Local Specialist MoE / expert model directories (will download from Hugging Face by default if left blank)
# POLYREASONER_MOE_DIR=./models
# POLYREASONER_EXPERTS_DIR=./models/experts

